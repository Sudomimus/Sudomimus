{
    "name": "@sudomimus/token",
    "version": "0.0.1",
    "description": "Sudomimus Token SDK — parse and verify Sudomimus access and refresh JWTs.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/sudomimus/sudomimus.git",
        "directory": "sdks/typescript/packages/token"
    },
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "compile": "tsc --project tsconfig.compile.json",
        "lint": "eslint src",
        "test": "jest",
        "release": "pnpm lint && pnpm test && pnpm compile",
        "release:dry-run": "pnpm release && pnpm pack --pack-destination /tmp && pnpm publish --dry-run --no-git-checks --access=public",
        "release:publish": "pnpm release && pnpm publish --no-git-checks --access=public"
    },
    "dependencies": {
        "@sudoo/jwt": "catalog:",
        "@sudoo/token": "catalog:"
    },
    "devDependencies": {
        "@types/jest": "catalog:",
        "@types/node": "catalog:",
        "jest": "catalog:",
        "ts-jest": "catalog:",
        "typescript": "catalog:"
    }
}