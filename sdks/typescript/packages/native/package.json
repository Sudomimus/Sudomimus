{
    "name": "@sudomimus/native",
    "version": "0.0.1",
    "description": "Sudomimus Native SDK — native client entry point.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/sudomimus/sudomimus.git",
        "directory": "sdks/typescript/packages/native"
    },
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "generate": "openapi-typescript ../../../../specs/native.yaml -o src/_generated/schema.ts",
        "compile": "tsc --project typescript/tsconfig.compile.json",
        "lint": "eslint src",
        "test": "jest"
    },
    "devDependencies": {
        "@types/jest": "catalog:",
        "@types/node": "catalog:",
        "jest": "catalog:",
        "openapi-typescript": "catalog:",
        "ts-jest": "catalog:",
        "typescript": "catalog:"
    }
}
